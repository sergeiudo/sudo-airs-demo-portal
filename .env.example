# ─── Prisma AIRS ─────────────────────────────────────────────────────────────
# API key from Strata Cloud Manager (SCM) → AI Security → API Applications
AIRS_API_KEY=your-airs-api-key-here

# Security profile name (created in SCM → AI Security → Security Profiles)
AIRS_PROFILE_NAME=your-profile-name

# Regional scan endpoint (choose your region):
#   US:        https://service.api.aisecurity.paloaltonetworks.com
#   EU (DE):   https://service-de.api.aisecurity.paloaltonetworks.com
#   India:     https://service-in.api.aisecurity.paloaltonetworks.com
#   Singapore: https://service-sg.api.aisecurity.paloaltonetworks.com
AIRS_BASE_URL=https://service.api.aisecurity.paloaltonetworks.com

# ─── Google Cloud / Vertex AI ────────────────────────────────────────────────
# GCP project ID
GCP_PROJECT_ID=your-gcp-project-id

# Vertex AI region (e.g. us-central1)
GCP_REGION=us-central1

# Vertex AI model (e.g. gemini-2.5-flash, gemini-2.5-pro)
VERTEX_MODEL=gemini-2.5-flash

# Path to your GCP service account JSON key file
# Leave blank to use Application Default Credentials (gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# ─── AWS Bedrock ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Bedrock model ARN or ID (e.g. anthropic.claude-opus-4-6-v1:0)
BEDROCK_MODEL_ID=anthropic.claude-opus-4-6-v1:0

# ─── Proxy server ────────────────────────────────────────────────────────────
# Port for the local Express proxy (Vite proxies /api → this port)
PROXY_PORT=3001

# ─── MCP Security Demo Server ────────────────────────────────────────────────
# Port for the MCP tool server (Vite proxies /mcp-tool → this port)
MCP_SERVER_PORT=8002

# ─── Portkey LLM Gateway (AI/LLM Gateway pillar) ─────────────────────────────
# The portal sends a different config per request (lane switcher + 3-lane compare),
# so this key MUST have "Allow Config Override" = ON in the Portkey console.
PORTKEY_API_KEY=
PORTKEY_CONFIG_AIRS=pc-sudo-t-5a505b          # sudo-demo-portal-airs-portkey  (PANW Prisma AIRS guardrail)
PORTKEY_CONFIG_NO_GUARDRAIL=pc-sudo-d-a72af9  # vestigial — no-guardrail lane bypasses Portkey (direct Vertex)
PORTKEY_CONFIG_DEFAULTS=pc-sudo-d-a72af9      # sudo-demo-portal-portkey       (native PII/code/word guardrails)
PORTKEY_CONFIG_FALLBACK=                       # no Bedrock provisioned → leave empty (fallback lane disabled)
PORTKEY_VERTEX_SLUG=@sudo-vertexai            # Vertex integration slug
PORTKEY_BEDROCK_SLUG=                          # Bedrock not provisioned in this workspace

# ─── Portkey FinOps (Budget tab) ───
# Admin/Organisation-scoped key with analytics-read + API-key-management scopes.
# Powers the Budget tab's real analytics dashboards + real budget enforcement
# (creates an isolated demo key with a cost cap). Distinct from PORTKEY_API_KEY.
# Optional override: FINOPS_DEMO_CAP_USD (default 1) — the demo key's cost cap.
PORTKEY_ADMIN_API_KEY=
# Per-model token budget for the Budget tab's developer chat (default 1000)
FINOPS_BUDGET_TOKEN_CAP=
